import sys
from pathlib import Path

# Start unresolved; only set when a valid project root is detected
PSM_ROOT = None

# Your declared dataset mount
DATASET_BASE = Path("/kaggle/input/datasets/kausikvaibhavpatra/psm-updated")

# Fast explicit candidates (including common nested layouts)
candidates = [
    DATASET_BASE / "PSM_Experiment_Setup_Research",
    DATASET_BASE / "PSM_Experiment_Research_Setup_Updated-main" / "PSM_Experiment_Research_Setup_Updated-main" / "PSM_Experiment_Setup_Research",
    Path("/kaggle/input/psm-experiment-research-setup-updated/PSM_Experiment_Setup_Research"),
    Path("/kaggle/input/psm-experiment/PSM_Experiment_Setup_Research"),
    Path.cwd() / "PSM_Experiment_Setup_Research",
    Path.cwd(),
]

def is_psm_root(p: Path) -> bool:
    return (
        (p / "router" / "router.py").exists()
        and (p / "llm").exists()
        and (p / "run_psm_experiments.py").exists()
    )

# 1) Try explicit candidates first
for c in candidates:
    if is_psm_root(c):
        PSM_ROOT = c
        break

# 2) Fallback: recursive search under your dataset mount, then /kaggle/input
if PSM_ROOT is None:
    search_roots = [DATASET_BASE, Path("/kaggle/input")]
    for root in search_roots:
        if not root.exists():
            continue
        for router_file in root.rglob("router.py"):
            parent = router_file.parent.parent  # .../<PSM_ROOT>/router/router.py -> <PSM_ROOT>
            if is_psm_root(parent):
                PSM_ROOT = parent
                break
        if PSM_ROOT is not None:
            break

if PSM_ROOT is None:
    raise RuntimeError(
        "PSM source tree not found.\n"
        "Checked explicit and recursive paths under your dataset mount.\n"
        "Please attach the latest dataset version and verify it contains:\n"
        "  - router/router.py\n"
        "  - llm/\n"
        "  - run_psm_experiments.py"
    )

sys.path.insert(0, str(PSM_ROOT))
print("PSM root:", PSM_ROOT)

